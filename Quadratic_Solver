#include <stdio.h>
#include <math.h>

void solveQuadratic(float a, float b, float c) {
    float discriminant, root1, root2;

    discriminant = b * b - 4 * a * c;

    if (discriminant > 0) {
        root1 = (-b + sqrt(discriminant)) / (2 * a);
        root2 = (-b - sqrt(discriminant)) / (2 * a);

        printf("Two real and distinct roots:\n");
        printf("Root 1 = %.2f\n", root1);
        printf("Root 2 = %.2f\n", root2);
    }
    else if (discriminant == 0) {
        root1 = -b / (2 * a);

        printf("One real repeated root:\n");
        printf("Root = %.2f\n", root1);
    }
    else {
        printf("No real roots.\n");
    }
}

int main() {
    float a, b, c;

    printf("Enter values of a, b, and c: ");

    /* Check for wrong data type or missing values */
    if (scanf("%f %f %f", &a, &b, &c) != 3) {
        printf("Error: Please enter 3 numeric values.\n");
        return 1;
    }

    /* Check if a is valid */
    if (a == 0) {
        printf("Error: a cannot be 0 in a quadratic equation.\n");
        return 1;
    }

    solveQuadratic(a, b, c);

    return 0;
}
